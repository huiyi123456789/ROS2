<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_robot">

  <xacro:property name="body_length" value="0.50"/>
  <xacro:property name="body_width" value="0.22"/>
  <xacro:property name="body_height" value="0.10"/>
  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_width" value="0.025"/>
  <xacro:property name="wheelbase" value="0.32"/>   <!-- 前后轴距 -->
  <xacro:property name="track" value="0.26"/>        <!-- 左右轮距 -->
  <xacro:property name="clearance" value="0.02"/>    <!-- 底盘离地间隙 -->

  <xacro:macro name="wheel_link" params="name x y z color">
    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="${name}_mat">
          <color rgba="${color}"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <inertial>
        <mass value="0.15"/>
        <inertia ixx="0.000143" ixy="0.0" ixz="0.0" iyy="0.00027" iyz="0.0" izz="0.000143"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + clearance + body_height/2}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.15 0.2 0.55 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.0146" ixy="0.0" ixz="0.0" iyy="0.065" iyz="0.0" izz="0.0746"/>
    </inertial>
  </link>

  <xacro:wheel_link name="wheel_left_rear"  x="${-wheelbase/2}" y="${track/2}"  z="${-(body_height/2 + clearance)}" color="0.2 0.2 0.2 1.0"/>
  <xacro:wheel_link name="wheel_right_rear" x="${-wheelbase/2}" y="${-track/2}" z="${-(body_height/2 + clearance)}" color="0.2 0.2 0.2 1.0"/>
  <xacro:wheel_link name="wheel_left_front"  x="${wheelbase/2}" y="${track/2}"  z="${-(body_height/2 + clearance)}" color="0.3 0.3 0.3 1.0"/>
  <xacro:wheel_link name="wheel_right_front" x="${wheelbase/2}" y="${-track/2}" z="${-(body_height/2 + clearance)}" color="0.3 0.3 0.3 1.0"/>

  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red">
        <color rgba="0.8 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${body_height/2 + 0.015}" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="green">
        <color rgba="0 0.7 0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${body_length/2 - 0.02} 0 ${body_height/2 - 0.01}" rpy="0 0 0"/>
  </joint>

</robot>
