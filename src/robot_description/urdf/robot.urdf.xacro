<?xml version="1.0"?>
<!-- TurtleBot3 Waffle 机器人描述文件（RViz 可视化用） -->
<!-- 基于官方 turtlebot3_description 包 -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="turtlebot3_waffle">

  <xacro:arg name="namespace" default=""/>
  <xacro:property name="namespace" value="$(arg namespace)"/>

  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
  <material name="dark"><color rgba="0.3 0.3 0.3 1.0"/></material>
  <material name="light_black"><color rgba="0.4 0.4 0.4 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
  <material name="green"><color rgba="0.0 0.8 0.0 1.0"/></material>
  <material name="red"><color rgba="0.8 0.0 0.0 1.0"/></material>

  <link name="${namespace}base_footprint"/>

  <joint name="${namespace}base_joint" type="fixed">
    <parent link="${namespace}base_footprint"/>
    <child link="${namespace}base_link"/>
    <origin xyz="0 0 0.010" rpy="0 0 0"/>
  </joint>

  <link name="${namespace}base_link">
    <visual>
      <origin xyz="-0.064 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://turtlebot3_description/meshes/bases/waffle_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="light_black"/>
    </visual>
    <collision>
      <origin xyz="-0.064 0 0.047" rpy="0 0 0"/>
      <geometry><box size="0.266 0.266 0.094"/></geometry>
    </collision>
    <inertial>
      <mass value="1.3729"/>
      <inertia ixx="0.0087" ixy="-4.76e-5" ixz="1.12e-4"
               iyy="0.00862" iyz="-3.54e-6"
               izz="0.01461"/>
    </inertial>
  </link>

  <!-- 左驱动轮 -->
  <joint name="${namespace}wheel_left_joint" type="continuous">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}wheel_left_link"/>
    <origin xyz="0.0 0.144 0.023" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="${namespace}wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://turtlebot3_description/meshes/wheels/left_tire.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.018" radius="0.033"/></geometry>
    </collision>
    <inertial>
      <mass value="0.0285"/>
      <inertia ixx="1.12e-5" ixy="0" ixz="0" iyy="1.12e-5" iyz="0" izz="2.07e-5"/>
    </inertial>
  </link>

  <!-- 右驱动轮 -->
  <joint name="${namespace}wheel_right_joint" type="continuous">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}wheel_right_link"/>
    <origin xyz="0.0 -0.144 0.023" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="${namespace}wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://turtlebot3_description/meshes/wheels/right_tire.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.018" radius="0.033"/></geometry>
    </collision>
    <inertial>
      <mass value="0.0285"/>
      <inertia ixx="1.12e-5" ixy="0" ixz="0" iyy="1.12e-5" iyz="0" izz="2.07e-5"/>
    </inertial>
  </link>

  <!-- 后万向轮 -->
  <link name="${namespace}caster_back_right_link">
    <collision>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry><box size="0.030 0.009 0.020"/></geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="${namespace}caster_back_right_joint" type="fixed">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}caster_back_right_link"/>
    <origin xyz="-0.177 -0.064 -0.004" rpy="-1.57 0 0"/>
  </joint>

  <link name="${namespace}caster_back_left_link">
    <collision>
      <origin xyz="0 0.001 0" rpy="0 0 0"/>
      <geometry><box size="0.030 0.009 0.020"/></geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="${namespace}caster_back_left_joint" type="fixed">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}caster_back_left_link"/>
    <origin xyz="-0.177 0.064 -0.004" rpy="-1.57 0 0"/>
  </joint>

  <!-- IMU -->
  <link name="${namespace}imu_link"/>
  <joint name="${namespace}imu_joint" type="fixed">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}imu_link"/>
    <origin xyz="0 0 0.068" rpy="0 0 0"/>
  </joint>

  <!-- LiDAR -->
  <link name="${namespace}base_scan">
    <visual>
      <geometry>
        <mesh filename="package://turtlebot3_description/meshes/sensors/lds.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0.015 0 -0.0065" rpy="0 0 0"/>
      <geometry><cylinder length="0.0315" radius="0.055"/></geometry>
    </collision>
    <inertial>
      <mass value="0.114"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="${namespace}scan_joint" type="fixed">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}base_scan"/>
    <origin xyz="-0.064 0 0.122" rpy="0 0 0"/>
  </joint>

  <!-- 摄像头 -->
  <link name="${namespace}camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 1.57"/>
      <geometry>
        <mesh filename="package://turtlebot3_description/meshes/sensors/r200.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.003 0.065 0.007" rpy="0 0 0"/>
      <geometry><box size="0.012 0.132 0.020"/></geometry>
    </collision>
  </link>
  <joint name="${namespace}camera_joint" type="fixed">
    <parent link="${namespace}base_link"/>
    <child link="${namespace}camera_link"/>
    <origin xyz="0.064 -0.065 0.094" rpy="0 0 0"/>
  </joint>

  <link name="${namespace}camera_rgb_frame"/>
  <joint name="${namespace}camera_rgb_joint" type="fixed">
    <parent link="${namespace}camera_link"/>
    <child link="${namespace}camera_rgb_frame"/>
    <origin xyz="0.005 0.018 0.013" rpy="0 0 0"/>
  </joint>

  <link name="${namespace}camera_rgb_optical_frame"/>
  <joint name="${namespace}camera_rgb_optical_joint" type="fixed">
    <parent link="${namespace}camera_rgb_frame"/>
    <child link="${namespace}camera_rgb_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57 0 -1.57"/>
  </joint>

</robot>
