<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="custom_robot">

    <!-- ===== 基础坐标帧（地面投影点） ===== -->
    <link name="base_footprint"/>

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
      <pose>0 0 0.13 0 0 0</pose>
    </joint>

    <!-- ===== 车体底盘 ===== -->
    <link name="base_link">
      <inertial>
        <mass>3.0</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia>
          <ixx>0.0146</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.065</iyy><iyz>0</iyz>
          <izz>0.0746</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry><box><size>0.50 0.22 0.10</size></box></geometry>
        <surface><friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction></surface>
      </collision>
      <visual name="base_visual">
        <geometry><box><size>0.50 0.22 0.10</size></box></geometry>
        <material>
          <ambient>0.1 0.15 0.4 1</ambient>
          <diffuse>0.15 0.2 0.55 1</diffuse>
          <specular>0.15 0.15 0.15 1</specular>
        </material>
      </visual>
    </link>

    <!-- ================================================================ -->
    <!--  驱动轮 — 后轮（左 / 右），由 diff_drive 插件控制               -->
    <!--  圆柱体绕 X 轴旋转 90°，对称轴从 Z 变为 Y（正常车轮朝向）        -->
    <!-- ================================================================ -->

    <!-- ----- 左后驱动轮 ----- -->
    <link name="wheel_left_rear_link">
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>1.43e-4</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.70e-4</iyy><iyz>0</iyz>
          <izz>1.43e-4</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.06</radius><length>0.025</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.06</radius><length>0.025</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
    </link>

    <joint name="wheel_left_rear_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_rear_link</child>
      <axis><xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.05</damping><friction>0.005</friction></dynamics>
      </axis>
      <pose>-0.16 0.13 -0.07 0 0 0</pose>
    </joint>

    <!-- ----- 右后驱动轮 ----- -->
    <link name="wheel_right_rear_link">
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>1.43e-4</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.70e-4</iyy><iyz>0</iyz>
          <izz>1.43e-4</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.06</radius><length>0.025</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.06</radius><length>0.025</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient></material>
      </visual>
    </link>

    <joint name="wheel_right_rear_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_rear_link</child>
      <axis><xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.05</damping><friction>0.005</friction></dynamics>
      </axis>
      <pose>-0.16 -0.13 -0.07 0 0 0</pose>
    </joint>

    <!-- ================================================================ -->
    <!--  随动轮 — 前轮（左 / 右），被动旋转，无驱动                       -->
    <!-- ================================================================ -->

    <!-- ----- 左前随动轮 ----- -->
    <link name="wheel_left_front_link">
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>1.14e-4</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.16e-4</iyy><iyz>0</iyz>
          <izz>1.14e-4</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.06</radius><length>0.025</length></cylinder></geometry>
        <surface><friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.06</radius><length>0.025</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient></material>
      </visual>
    </link>

    <joint name="wheel_left_front_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_front_link</child>
      <axis><xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.05</damping><friction>0.005</friction></dynamics>
      </axis>
      <pose>0.16 0.13 -0.07 0 0 0</pose>
    </joint>

    <!-- ----- 右前随动轮 ----- -->
    <link name="wheel_right_front_link">
      <inertial>
        <mass>0.12</mass>
        <inertia>
          <ixx>1.14e-4</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>2.16e-4</iyy><iyz>0</iyz>
          <izz>1.14e-4</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.06</radius><length>0.025</length></cylinder></geometry>
        <surface><friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction></surface>
      </collision>
      <visual name="visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.06</radius><length>0.025</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient></material>
      </visual>
    </link>

    <joint name="wheel_right_front_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_front_link</child>
      <axis><xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.05</damping><friction>0.005</friction></dynamics>
      </axis>
      <pose>0.16 -0.13 -0.07 0 0 0</pose>
    </joint>

    <!-- ================================================================ -->
    <!--  传感器平台                                                     -->
    <!-- ================================================================ -->

    <!-- ----- 车顶 LiDAR 支架（初始关闭） ----- -->
    <link name="lidar_link">
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.04</radius><length>0.03</length></cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.04</radius><length>0.03</length></cylinder>
        </geometry>
        <material>
          <ambient>0.8 0.2 0.2 1</ambient>
          <diffuse>0.8 0.2 0.2 1</diffuse>
        </material>
      </visual>

      <sensor name="lidar_sensor" type="ray">
        <pose>0 0 0 0 0 0</pose>
        <always_on>0</always_on>
        <visualize>false</visualize>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <plugin name="gpu_lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>robot</namespace>
            <argument>~/out:=scan</argument>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>lidar_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
      <pose>0 0 0.08 0 0 0</pose>
    </joint>

    <!-- ----- 内置 IMU ----- -->
    <link name="imu_link">
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>200</update_rate>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.00017</stddev></noise>
            </x>
            <y>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.00017</stddev></noise>
            </y>
            <z>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.00017</stddev></noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.001</stddev></noise>
            </x>
            <y>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.001</stddev></noise>
            </y>
            <z>
              <noise type="gaussian"><mean>0.0</mean><stddev>0.001</stddev></noise>
            </z>
          </linear_acceleration>
        </imu>
        <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <namespace>robot</namespace>
          </ros>
          <frame_name>imu_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>base_link</parent>
      <child>imu_link</child>
      <pose>0 0 -0.02 0 0 0</pose>
    </joint>

    <!-- ----- 前向 RGB 摄像头 ----- -->
    <link name="camera_link">
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-6</iyy><iyz>0</iyz>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><box><size>0.02 0.04 0.02</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.02 0.04 0.02</size></box></geometry>
        <material>
          <ambient>0 0.7 0 1</ambient>
          <diffuse>0 0.7 0 1</diffuse>
        </material>
      </visual>
      <sensor name="camera_sensor" type="camera">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>false</visualize>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
        <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>robot</namespace>
          </ros>
          <frame_name>camera_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
      <pose>0.23 0 0.06 0 0 0</pose>
    </joint>

    <!-- ================================================================ -->
    <!--  Gazebo ROS 差分驱动插件 — 后轮驱动                              -->
    <!-- ================================================================ -->
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>robot</namespace>
      </ros>
      <update_rate>30</update_rate>
      <left_joint>wheel_left_rear_joint</left_joint>
      <right_joint>wheel_right_rear_joint</right_joint>
      <wheel_separation>0.26</wheel_separation>
      <wheel_diameter>0.12</wheel_diameter>
      <max_wheel_torque>8.0</max_wheel_torque>
      <max_wheel_acceleration>0.5</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <publishTf>1</publishTf>
    </plugin>

    <!-- ===== 关节状态发布插件 — 发布全部四个轮子的状态 ===== -->
    <plugin name="joint_state_publisher"
            filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>robot</namespace>
      </ros>
      <update_rate>30</update_rate>
      <joint_name>wheel_left_rear_joint</joint_name>
      <joint_name>wheel_right_rear_joint</joint_name>
      <joint_name>wheel_left_front_joint</joint_name>
      <joint_name>wheel_right_front_joint</joint_name>
    </plugin>

  </model>
</sdf>
