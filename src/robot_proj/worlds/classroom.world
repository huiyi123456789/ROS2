    <!-- ===== 东墙可开关门（门框静态 + 门板动态，世界级铰链连接） ===== -->
    <model name="door_frame">
      <static>true</static>
      <pose>4.92 -1.5 1.0 0 0 0</pose>
      <link name="link">
        <collision name="frame_collision">
          <geometry><box><size>0.06 1.02 2.16</size></box></geometry>
        </collision>
        <visual name="frame_visual">
          <geometry><box><size>0.06 1.02 2.16</size></box></geometry>
          <material>
            <ambient>0.545 0.353 0.169 1</ambient>
            <diffuse>0.545 0.353 0.169 1</diffuse>
            <specular>0 0 0 0</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 门板（动态，可旋转） -->
    <model name="door_panel">
      <pose>4.92 -1.5 1.0 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>20</mass>
          <inertia>
            <ixx>6.671</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>8.017</iyy><iyz>0</iyz>
            <izz>1.354</izz>
          </inertia>
        </inertial>
        <collision name="door_collision">
          <geometry><box><size>0.05 0.9 2.0</size></box></geometry>
        </collision>
        <visual name="door_visual">
          <geometry><box><size>0.05 0.9 2.0</size></box></geometry>
          <material>
            <ambient>0.824 0.706 0.549 1</ambient>
            <diffuse>0.824 0.706 0.549 1</diffuse>
            <specular>0.05 0.05 0.05 0.05</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 门铰链（世界级关节，连接门框和门板） -->
    <joint name="door_hinge" type="revolute">
      <parent>door_frame::link</parent>
      <child>door_panel::link</child>
      <pose>4.92 -1.95 1.0 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.57</lower>
          <upper>0</upper>
          <effort>100</effort>
        </limit>
        <dynamics>
          <damping>0.5</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
    </joint>

