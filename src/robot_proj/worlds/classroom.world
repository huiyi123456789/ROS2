<?xml version="1.0" ?>
<sdf version="1.7">
  <world name="classroom_world">

    <!-- ===== 物理引擎配置 ===== -->
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <sor>1.3</sor>
        </solver>
        <constraints>
          <cfm>0</cfm>
          <erp>0.2</erp>
        </constraints>
      </ode>
    </physics>

    <!-- ===== 地面（瓷砖地板） ===== -->
    <model name="floor">
      <static>true</static>
      <pose>0 0 -0.025 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>10 8 0.05</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
            <contact>
              <ode>
                <soft_cfm>0</soft_cfm>
                <soft_erp>0.2</soft_erp>
                <kp>1e5</kp>
                <kd>1</kd>
                <max_vel>0.01</max_vel>
                <min_depth>0.001</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>10 8 0.05</size></box></geometry>
          <material>
            <ambient>0.75 0.73 0.68 1</ambient>
            <diffuse>0.75 0.73 0.68 1</diffuse>
            <specular>0.05 0.05 0.05 0.05</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ===== 场景光照 ===== -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.8 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.3 -0.9</direction>
    </light>

    <light name="ambient_fill" type="directional">
      <diffuse>0.5 0.5 0.55 1</diffuse>
      <specular>0 0 0 0</specular>
      <direction>0.5 0.5 -0.5</direction>
    </light>

    <light name="ceiling_light_center" type="point">
      <pose>0 0 2.9 0 0 0</pose>
      <diffuse>0.95 0.95 0.85 1</diffuse>
      <specular>0.05 0.05 0.05 1</specular>
      <attenuation>
        <range>8</range>
        <constant>0.5</constant>
        <linear>0.1</linear>
        <quadratic>0.02</quadratic>
      </attenuation>
    </light>

    <!-- ===== 教室墙壁（4面，浅绿色 #D0F0C0 ≈ 0.816 0.941 0.753） ===== -->

    <!-- 北墙（后墙/黑板墙，y=4） -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 4 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>10 0.2 3.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>10 0.2 3.0</size></box></geometry>
          <material>
            <ambient>0.816 0.941 0.753 1</ambient>
            <diffuse>0.816 0.941 0.753 1</diffuse>
            <specular>0 0 0 0</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 南墙（前墙/窗墙，y=-4） -->
