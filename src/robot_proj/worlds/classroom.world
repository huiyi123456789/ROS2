    <!-- ===== 垃圾桶（东南墙角，可被撞倒） ===== -->
    <model name="trash_bin">
      <pose>4.7 -3.7 0.2 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.038</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.038</iyy><iyz>0</iyz>
            <izz>0.023</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><cylinder><radius>0.15</radius><length>0.4</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.15</radius><length>0.4</length></cylinder></geometry>
          <material>
            <ambient>0.3 0.35 0.4 1</ambient>
            <diffuse>0.3 0.35 0.4 1</diffuse>
            <specular>0.1 0.1 0.1 0.1</specular>
          </material>
        </visual>
      </link>
    </model>

