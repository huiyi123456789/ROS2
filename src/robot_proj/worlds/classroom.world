          <material>
            <ambient>0.816 0.941 0.753 1</ambient>
            <diffuse>0.816 0.941 0.753 1</diffuse>
            <specular>0 0 0 0</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 东墙（x=5，分三段留出门洞：门宽0.9m，门高2.0m，门中心y=-1.5） -->
